# ── LLM ───────────────────────────────────────────────────────
# Groq (free — 14,400 req/day): https://console.groq.com → API Keys
GROQ_API_KEY=

# OpenAI (paid fallback): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Embeddings ─────────────────────────────────────────────────
# HuggingFace Inference API (free): https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ── Database (Supabase or any PostgreSQL) ──────────────────────
# Project Settings → Database
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Neo4j (Phase 7 — Advanced Mode graph retrieval) ───────────
# Free AuraDB instance: https://neo4j.com/cloud/aura-free/
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── App env ────────────────────────────────────────────────────
APP_ENV=development

# All other settings (models, limits, retrieval params) live in config.yaml
